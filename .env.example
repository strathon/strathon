# Strathon environment overrides.
# Copy to .env to customize. All values shown are the defaults; uncomment
# only what you want to change. The receiver works with no .env at all.

# ---- Postgres ----
# POSTGRES_PASSWORD=strathon_dev

# ---- Receiver logging ----
# STRATHON_LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
# STRATHON_LOG_FORMAT=text         # text | json (json emits one record per line)

# ---- Database pool ----
# STRATHON_DB_POOL_SIZE=10
# STRATHON_DB_MAX_OVERFLOW=20
# STRATHON_DB_POOL_TIMEOUT=30
# STRATHON_DB_POOL_RECYCLE=3600
# STRATHON_DB_ECHO=false           # true to log all SQL queries

# ---- Sampling ----
# STRATHON_SAMPLING_RATE=1.0       # 0.0-1.0. Always-keep rules still apply.

# ---- Retention ----
# STRATHON_RETENTION_ENABLED=true
# STRATHON_RETENTION_INTERVAL_SECONDS=3600
# STRATHON_RETENTION_BATCH_SIZE=5000
# STRATHON_SPAN_PARTITION_RETENTION_MONTHS=12

# ---- Authentication / RBAC ----
# STRATHON_REGISTRATION_ENABLED=true    # false to require admin invitation
# STRATHON_SESSION_TTL_HOURS=24         # dashboard session lifetime (1-720)
# STRATHON_COOKIE_SECURE=false          # set true only when serving the dashboard over HTTPS
# STRATHON_LOGIN_RATE_LIMIT_ATTEMPTS=5  # max login attempts per IP per window
# STRATHON_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
# STRATHON_LOCKOUT_ATTEMPTS=10          # lock account after N failed attempts
# STRATHON_LOCKOUT_MINUTES=15
# STRATHON_MAX_SESSIONS=5               # max concurrent sessions per user
# STRATHON_PASSWORD_PEPPER=             # optional Argon2id pepper (hex string)

# ---- Security ----
# STRATHON_ENCRYPTION_KEY=              # Fernet key for column-level encryption
# STRATHON_AUDIT_HMAC_KEY=              # HMAC-SHA256 key for audit hash chain
# STRATHON_AUDIT_ANCHOR_INTERVAL_SECONDS=60
# STRATHON_AUDIT_HOT_MONTHS=6
# STRATHON_DOCS_ENABLED=false           # true to expose /docs (Swagger UI)
# STRATHON_CORS_ORIGINS=http://localhost:3000
# STRATHON_METRICS_AUTH_TOKEN=           # optional bearer token for /metrics

# ---- Rate limiting ----
# STRATHON_RATE_LIMIT_ENABLED=true
# STRATHON_RATE_LIMIT_REQUESTS_PER_SECOND=100
# STRATHON_RATE_LIMIT_BURST=200

# ---- Webhooks ----
# STRATHON_WEBHOOK_MAX_ATTEMPTS=5
# STRATHON_WEBHOOK_MIN_BACKOFF_MS=1000
# STRATHON_WEBHOOK_MAX_BACKOFF_MS=60000
# STRATHON_WEBHOOK_REQUEST_TIMEOUT_SEC=10
# STRATHON_WEBHOOK_SIGNING_SECRETS=     # comma-separated HMAC keys

# ---- Circuit breakers ----
# STRATHON_CB_ERROR_THRESHOLD=5
# STRATHON_CB_WINDOW_SECONDS=60
# STRATHON_CB_COOLDOWN_SECONDS=30
# STRATHON_CB_HALF_OPEN_MAX=3

# ---- Behavioral drift (Vigil) ----
# STRATHON_VIGIL_EWMA_ALPHA=0.3
# STRATHON_VIGIL_CUSUM_THRESHOLD=5.0
# STRATHON_VIGIL_CUSUM_DRIFT=1.0
# STRATHON_VIGIL_MIN_SPANS=50

# ---- Budget evaluation ----
# STRATHON_BUDGET_EVAL_INTERVAL_SECONDS=300
# STRATHON_BUDGET_MAX_PER_TICK=100

# ---- Agent heartbeat ----
# STRATHON_HEARTBEAT_TIMEOUT_SECONDS=300

# ---- Deployment mode ----
# STRATHON_MODE=self-hosted         # self-hosted | cloud
# STRATHON_AUTO_MIGRATE=true        # run alembic upgrade head on startup

# ---- Integrations ----
# STRATHON_SLACK_SIGNING_SECRET=    # Slack app signing secret
# STRATHON_EGRESS_RECEIVER_URL=     # URL for egress proxy

# ---- Email (optional, for password reset) ----
# STRATHON_SMTP_HOST=
# STRATHON_SMTP_PORT=587
# STRATHON_SMTP_USER=
# STRATHON_SMTP_PASSWORD=
# STRATHON_SMTP_FROM=noreply@getstrathon.com

# AI Policy Generation (optional — enables --from-english in CLI)
# Supports Anthropic (sk-ant-...) or OpenAI (sk-...) keys.
STRATHON_AI_API_KEY=
