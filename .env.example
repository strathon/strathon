# Strathon environment overrides.
# Copy to .env to customize. All values shown are the defaults; uncomment
# only what you want to change. The receiver works with no .env at all.

# ---- Postgres ----
# POSTGRES_PASSWORD=strathon_dev

# ---- Receiver logging ----
# STRATHON_LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
# STRATHON_LOG_FORMAT=text         # text | json (json emits one record per line)

# ---- Sampling ----
# STRATHON_SAMPLING_RATE=1.0       # 0.0-1.0. Always-keep rules still apply.

# ---- Retention ----
# STRATHON_RETENTION_ENABLED=true
# STRATHON_RETENTION_INTERVAL_SECONDS=3600
# STRATHON_RETENTION_BATCH_SIZE=5000

# ---- Authentication / RBAC ----
# STRATHON_REGISTRATION_ENABLED=true    # false to require admin invitation
# STRATHON_SESSION_TTL_HOURS=24         # dashboard session lifetime (1-720)
# STRATHON_LOGIN_RATE_LIMIT_ATTEMPTS=5  # max login attempts per IP per window
# STRATHON_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
