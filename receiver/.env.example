# Strathon Receiver — Environment Variables
# Copy to .env and fill in values.
# All variables are optional except DATABASE_URL.

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://strathon:strathon_dev@localhost:5432/strathon

# ── Security ──────────────────────────────────────────────────
# HMAC key for tamper-evident audit log hash chain.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STRATHON_AUDIT_HMAC_KEY=

# Fernet key for column-level encryption (TOTP secrets, webhook secrets).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STRATHON_ENCRYPTION_KEY=

# Secret prepended to passwords before Argon2id hashing.
# Even with full DB access, attacker can't crack passwords without this.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
STRATHON_PASSWORD_PEPPER=

# ── Registration ──────────────────────────────────────────────
# Set to false after creating initial admin account.
STRATHON_REGISTRATION_ENABLED=true

# ── Session ───────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ── Rate Limiting ─────────────────────────────────────────────
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=60

# ── Account Lockout ───────────────────────────────────────────
STRATHON_LOCKOUT_ATTEMPTS=5
STRATHON_LOCKOUT_MINUTES=15
STRATHON_MAX_SESSIONS=10

# ── Production Hardening ──────────────────────────────────────
# Enable Swagger UI (/docs, /redoc). Default: disabled.
STRATHON_DOCS_ENABLED=false

# Bearer token required to access /metrics endpoint.
STRATHON_METRICS_AUTH_TOKEN=

# Comma-separated list of allowed CORS origins.
STRATHON_CORS_ORIGINS=http://localhost:3000

# Comma-separated CIDR list of trusted reverse proxy IPs.
# Never set to * in production.
STRATHON_TRUSTED_PROXIES=127.0.0.1

# ── Email (optional, for password reset) ──────────────────────
STRATHON_SMTP_HOST=
STRATHON_SMTP_PORT=587
STRATHON_SMTP_USER=
STRATHON_SMTP_PASSWORD=
STRATHON_SMTP_FROM=noreply@getstrathon.com

# ── Slack Integration ─────────────────────────────────────────
STRATHON_SLACK_SIGNING_SECRET=

# ── Vigil (behavioral drift detection) ────────────────────────
STRATHON_VIGIL_MIN_SPANS=100
STRATHON_VIGIL_EWMA_ALPHA=0.3
STRATHON_VIGIL_CUSUM_THRESHOLD=5.0

# ── Circuit Breakers ──────────────────────────────────────────
STRATHON_CB_ERROR_THRESHOLD=10
STRATHON_CB_WINDOW_SECONDS=300
STRATHON_CB_COOLDOWN_SECONDS=60
